# --- Database (Supabase Postgres) ---
# Supabase project: https://supabase.com → Project → Settings → Database → Connection pooling
# Transaction mode (port 6543) — used by runtime queries
DATABASE_URL=postgresql://USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Session mode (port 5432) — used only for migrations (DDL doesn't play well with pgbouncer)
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Service ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Auth (ingest endpoints only; metrics endpoints are public) ---
# Min 32 chars. Render generates this automatically when using the Blueprint.
API_SECRET=change-me-min-32-chars-long-random-token

# --- Stripe test mode ---
# Get from https://dashboard.stripe.com (Test mode toggle ON) → Developers → API keys
STRIPE_TEST_KEY=sk_test_...

# --- Ingest behavior ---
# Only ingest transactions occurring on or after this ISO date.
# Prevents pulling years of historical test data on first run.
INGEST_START_DATE=2024-01-01

# --- Mock CSV source ---
# Path to the seed CSV (default: src/sources/mock/data.csv); leave default.
MOCK_CSV_PATH=src/sources/mock/data.csv
